{
  "tools": [
    {
      "name": "get_cpu_info",
      "description": "Parse /proc/cpuinfo; return model, core count, frequency, and flags.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "format": {
            "type": "string",
            "description": "'summary' or 'detailed'",
            "enum": ["summary", "detailed"]
          }
        }
      }
    },
    {
      "name": "get_memory_info",
      "description": "Parse /proc/meminfo; return total, free, available, swap, and cache.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "units": {
            "type": "string",
            "description": "Display units",
            "enum": ["KB", "MB", "GB"]
          }
        }
      }
    },
    {
      "name": "get_process_info",
      "description": "Fetch status, memory, cmdline, and environ for a process by PID.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "pid": {
            "type": "number",
            "description": "Process ID"
          },
          "include_environ": {
            "type": "boolean",
            "description": "Include environment variables"
          },
          "include_maps": {
            "type": "boolean",
            "description": "Include memory mappings"
          }
        },
        "required": ["pid"]
      }
    },
    {
      "name": "list_processes",
      "description": "List running processes from /proc with PID, name, and state.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "filter_by_name": {
            "type": "string",
            "description": "Partial name filter"
          },
          "sort_by": {
            "type": "string",
            "description": "Sort field",
            "enum": ["pid", "name", "memory", "cpu"]
          }
        }
      }
    },
    {
      "name": "get_network_stats",
      "description": "Read /proc/net/dev; return per-interface TX/RX bytes and packets.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "interface": {
            "type": "string",
            "description": "Interface name; omit for all"
          }
        }
      }
    },
    {
      "name": "get_system_uptime",
      "description": "Read /proc/uptime; return system uptime and idle time.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "format": {
            "type": "string",
            "description": "'seconds' or 'human_readable'",
            "enum": ["seconds", "human_readable"]
          }
        }
      }
    },
    {
      "name": "get_load_average",
      "description": "Read /proc/loadavg; return 1, 5, and 15-min load averages.",
      "inputSchema": {
        "type": "object",
        "properties": {}
      }
    },
    {
      "name": "get_disk_stats",
      "description": "Read /proc/diskstats; return per-device read/write ops and sectors.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "device": {
            "type": "string",
            "description": "Device name; omit for all"
          }
        }
      }
    },
    {
      "name": "get_filesystem_mounts",
      "description": "Read /proc/mounts; return mount points, FS types, and options.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "mount_point": {
            "type": "string",
            "description": "Mount point filter"
          }
        }
      }
    },
    {
      "name": "get_interrupts",
      "description": "Read /proc/interrupts; return per-CPU interrupt counts by IRQ.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "irq_number": {
            "type": "number",
            "description": "IRQ number; omit for all",
            "minimum": 0
          }
        }
      }
    }
  ]
}
