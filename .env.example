# MCP Client Web - Environment Configuration
# Copy this file to .env and configure your values

# ============================================================================
# Security Settings
# ============================================================================

# Allow HTTP for MCP servers (SECURITY: Set to true ONLY for development)
# Production default: false (enforces HTTPS)
MCP_ALLOW_HTTP_INSECURE=true

# ============================================================================
# MCP Server Settings
# ============================================================================

# Default request timeout in milliseconds
MCP_REQUEST_TIMEOUT_MS=20000

# Maximum tool calls per conversation turn (prevent loops)
MCP_MAX_TOOL_CALLS_PER_TURN=8

# Tool result size limits
MCP_MAX_RESULT_PREVIEW_CHARS=4000
MCP_MAX_TOOL_OUTPUT_CHARS_TO_LLM=12000

# ============================================================================
# LLM Provider Settings - OpenAI
# ============================================================================

# OpenAI API key (required for OpenAI provider)
OPENAI_API_KEY=sk-your-api-key-here

# OpenAI base URL (change for OpenAI-compatible APIs)
OPENAI_BASE_URL=https://api.openai.com

# ============================================================================
# LLM Provider Settings - Ollama
# ============================================================================

# Ollama base URL (local or remote instance)
# Examples:
#   Local: http://127.0.0.1:11434
#   Remote: http://192.168.1.50:11434
OLLAMA_BASE_URL=http://127.0.0.1:11434

# ============================================================================
# Logging Settings
# ============================================================================

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
