{
  "server_info": {
    "name": "proc-analyzer",
    "version": "1.0.0",
    "description": "MCP server for analyzing Linux /proc filesystem",
    "author": "System Tools Team",
    "platform": "linux"
  },
  "tools": [
    {
      "name": "get_cpu_info",
      "description": "Parse /proc/cpuinfo; return model, core count, frequency, and flags.",
      "category": "system",
      "inputSchema": {
        "type": "object",
        "properties": {
          "format": {
            "type": "string",
            "description": "'summary' or 'detailed'",
            "enum": ["summary", "detailed"]
          }
        },
        "required": []
      },
      "outputSchema": {
        "type": "object",
        "description": "CPU information object with processor details"
      },
      "examples": [
        {
          "description": "Get CPU summary",
          "input": {
            "format": "summary"
          },
          "expectedOutput": {
            "processor_count": 8,
            "model_name": "Intel(R) Core(TM) i7-9750H CPU @ 2.60GHz",
            "cpu_mhz": "2600.000",
            "cache_size": "12288 KB",
            "cores_per_cpu": "6",
            "vendor_id": "GenuineIntel"
          }
        },
        {
          "description": "Get detailed CPU information",
          "input": {
            "format": "detailed"
          }
        }
      ]
    },
    {
      "name": "get_memory_info",
      "description": "Parse /proc/meminfo; return total, free, available, swap, and cache.",
      "category": "system",
      "inputSchema": {
        "type": "object",
        "properties": {
          "units": {
            "type": "string",
            "description": "Display units",
            "enum": ["KB", "MB", "GB"]
          }
        },
        "required": []
      },
      "outputSchema": {
        "type": "object",
        "description": "Memory information with usage statistics"
      },
      "examples": [
        {
          "description": "Get memory info in megabytes",
          "input": {
            "units": "MB"
          },
          "expectedOutput": {
            "total_memory": "16384.00 MB",
            "free_memory": "2048.00 MB",
            "available_memory": "8192.00 MB",
            "buffers": "512.00 MB",
            "cached": "4096.00 MB",
            "swap_total": "8192.00 MB",
            "swap_free": "8192.00 MB",
            "units": "MB"
          }
        },
        {
          "description": "Get memory info in gigabytes",
          "input": {
            "units": "GB"
          }
        }
      ]
    },
    {
      "name": "get_process_info",
      "description": "Fetch status, memory, cmdline, and environ for a process by PID.",
      "category": "process",
      "inputSchema": {
        "type": "object",
        "properties": {
          "pid": {
            "type": "number",
            "description": "Process ID",
            "minimum": 1
          },
          "include_environ": {
            "type": "boolean",
            "description": "Include environment variables"
          },
          "include_maps": {
            "type": "boolean",
            "description": "Include memory mappings"
          }
        },
        "required": ["pid"]
      },
      "outputSchema": {
        "type": "object",
        "description": "Detailed process information"
      },
      "examples": [
        {
          "description": "Get basic info for init process",
          "input": {
            "pid": 1,
            "include_environ": false,
            "include_maps": false
          }
        },
        {
          "description": "Get full process info with environment",
          "input": {
            "pid": 1234,
            "include_environ": true,
            "include_maps": true
          }
        }
      ]
    },
    {
      "name": "list_processes",
      "description": "List running processes from /proc with PID, name, and state.",
      "category": "process",
      "inputSchema": {
        "type": "object",
        "properties": {
          "filter_by_name": {
            "type": "string",
            "description": "Partial name filter (case-insensitive)"
          },
          "sort_by": {
            "type": "string",
            "description": "Sort field",
            "enum": ["pid", "name", "memory", "cpu"]
          }
        },
        "required": []
      },
      "outputSchema": {
        "type": "array",
        "description": "List of processes with basic information",
        "items": {
          "type": "object"
        }
      },
      "examples": [
        {
          "description": "List all processes sorted by PID",
          "input": {
            "sort_by": "pid"
          }
        },
        {
          "description": "Find all Python processes sorted by memory",
          "input": {
            "filter_by_name": "python",
            "sort_by": "memory"
          }
        },
        {
          "description": "List all processes sorted by name",
          "input": {
            "sort_by": "name"
          }
        }
      ]
    },
    {
      "name": "get_network_stats",
      "description": "Read /proc/net/dev; return per-interface TX/RX bytes and packets.",
      "category": "network",
      "inputSchema": {
        "type": "object",
        "properties": {
          "interface": {
            "type": "string",
            "description": "Interface name; omit for all"
          }
        },
        "required": []
      },
      "outputSchema": {
        "type": "object",
        "description": "Network statistics per interface"
      },
      "examples": [
        {
          "description": "Get stats for all interfaces",
          "input": {}
        },
        {
          "description": "Get stats for specific interface",
          "input": {
            "interface": "eth0"
          }
        },
        {
          "description": "Get loopback interface stats",
          "input": {
            "interface": "lo"
          }
        }
      ]
    },
    {
      "name": "get_system_uptime",
      "description": "Read /proc/uptime; return system uptime and idle time.",
      "category": "system",
      "inputSchema": {
        "type": "object",
        "properties": {
          "format": {
            "type": "string",
            "description": "'seconds' or 'human_readable'",
            "enum": ["seconds", "human_readable"]
          }
        },
        "required": []
      },
      "outputSchema": {
        "type": "object",
        "description": "System uptime information"
      },
      "examples": [
        {
          "description": "Get uptime in human-readable format",
          "input": {
            "format": "human_readable"
          },
          "expectedOutput": {
            "uptime": "5d 12h 34m 56s",
            "uptime_seconds": 475496.0,
            "idle_seconds": 1234567.89,
            "idle_time": "342.94 hours"
          }
        },
        {
          "description": "Get uptime in seconds",
          "input": {
            "format": "seconds"
          }
        }
      ]
    },
    {
      "name": "get_load_average",
      "description": "Read /proc/loadavg; return 1, 5, and 15-min load averages.",
      "category": "system",
      "inputSchema": {
        "type": "object",
        "properties": {},
        "required": []
      },
      "outputSchema": {
        "type": "object",
        "description": "Load average statistics"
      },
      "examples": [
        {
          "description": "Get current load average",
          "input": {},
          "expectedOutput": {
            "load_1min": 1.23,
            "load_5min": 0.98,
            "load_15min": 0.75,
            "running_processes": "2",
            "total_processes": "345",
            "last_pid": 12345
          }
        }
      ]
    },
    {
      "name": "get_disk_stats",
      "description": "Read /proc/diskstats; return per-device read/write ops and sectors.",
      "category": "storage",
      "inputSchema": {
        "type": "object",
        "properties": {
          "device": {
            "type": "string",
            "description": "Device name; omit for all"
          }
        },
        "required": []
      },
      "outputSchema": {
        "type": "object",
        "description": "Disk I/O statistics per device"
      },
      "examples": [
        {
          "description": "Get stats for all disk devices",
          "input": {}
        },
        {
          "description": "Get stats for primary disk",
          "input": {
            "device": "sda"
          }
        },
        {
          "description": "Get stats for NVMe drive",
          "input": {
            "device": "nvme0n1"
          }
        }
      ]
    },
    {
      "name": "get_filesystem_mounts",
      "description": "Read /proc/mounts; return mount points, FS types, and options.",
      "category": "storage",
      "inputSchema": {
        "type": "object",
        "properties": {
          "mount_point": {
            "type": "string",
            "description": "Mount point filter"
          }
        },
        "required": []
      },
      "outputSchema": {
        "type": "array",
        "description": "List of mounted filesystems",
        "items": {
          "type": "object"
        }
      },
      "examples": [
        {
          "description": "Get all mounted filesystems",
          "input": {}
        },
        {
          "description": "Get info for root filesystem",
          "input": {
            "mount_point": "/"
          }
        },
        {
          "description": "Get info for home directory mount",
          "input": {
            "mount_point": "/home"
          }
        }
      ]
    },
    {
      "name": "get_interrupts",
      "description": "Read /proc/interrupts; return per-CPU interrupt counts by IRQ.",
      "category": "system",
      "inputSchema": {
        "type": "object",
        "properties": {
          "irq_number": {
            "type": "number",
            "description": "IRQ number; omit for all",
            "minimum": 0
          }
        },
        "required": []
      },
      "outputSchema": {
        "type": "object",
        "description": "Interrupt statistics per IRQ"
      },
      "examples": [
        {
          "description": "Get all interrupt statistics",
          "input": {}
        },
        {
          "description": "Get stats for specific IRQ",
          "input": {
            "irq_number": 16
          }
        }
      ]    },
    {
      "name": "list_systemd_services",
      "description": "List systemd services with name, load-state, active-state, and sub-state.",
      "category": "systemd",
      "inputSchema": {
        "type": "object",
        "properties": {
          "state": {
            "type": "string",
            "description": "Filter by service state",
            "enum": ["active", "inactive", "failed", "running", "exited", "dead", "all"]
          },
          "pattern": {
            "type": "string",
            "description": "Service name pattern filter"
          }
        },
        "required": []
      },
      "outputSchema": {
        "type": "array",
        "description": "List of systemd services with status information"
      },
      "examples": [
        {
          "description": "List all services",
          "input": {
            "state": "all"
          }
        },
        {
          "description": "List only active services",
          "input": {
            "state": "active"
          }
        },
        {
          "description": "List failed services",
          "input": {
            "state": "failed"
          }
        },
        {
          "description": "Find SSH-related services",
          "input": {
            "pattern": "ssh"
          }
        }
      ]
    },
    {
      "name": "get_service_status",
      "description": "Get active-state, memory, PID, uptime, and optional logs for a systemd service.",
      "category": "systemd",
      "inputSchema": {
        "type": "object",
        "properties": {
          "service_name": {
            "type": "string",
            "description": "Service name (with or without .service suffix)"
          },
          "include_logs": {
            "type": "boolean",
            "description": "Include recent log entries"
          },
          "log_lines": {
            "type": "number",
            "description": "Log lines to include",
            "minimum": 1,
            "maximum": 1000
          }
        },
        "required": ["service_name"]
      },
      "outputSchema": {
        "type": "object",
        "description": "Detailed service status information"
      },
      "examples": [
        {
          "description": "Get SSH service status",
          "input": {
            "service_name": "sshd"
          }
        },
        {
          "description": "Get service status with logs",
          "input": {
            "service_name": "nginx",
            "include_logs": true,
            "log_lines": 50
          }
        }
      ]
    },
    {
      "name": "get_service_logs",
      "description": "Get systemd journal logs for a specific service using journalctl.",
      "category": "systemd",
      "inputSchema": {
        "type": "object",
        "properties": {
          "service_name": {
            "type": "string",
            "description": "Service name"
          },
          "lines": {
            "type": "number",
            "description": "Log lines to fetch",
            "minimum": 1,
            "maximum": 10000
          },
          "since": {
            "type": "string",
            "description": "Time filter (e.g., '1 hour ago', 'yesterday')"
          },
          "priority": {
            "type": "string",
            "description": "Priority filter",
            "enum": ["emerg", "alert", "crit", "err", "warning", "notice", "info", "debug"]
          }
        },
        "required": ["service_name"]
      },
      "outputSchema": {
        "type": "object",
        "description": "Service logs with metadata"
      },
      "examples": [
        {
          "description": "Get last 100 lines",
          "input": {
            "service_name": "nginx",
            "lines": 100
          }
        },
        {
          "description": "Get logs from last hour",
          "input": {
            "service_name": "sshd",
            "since": "1 hour ago"
          }
        },
        {
          "description": "Get error logs only",
          "input": {
            "service_name": "mysql",
            "priority": "err",
            "lines": 50
          }
        }
      ]
    },
    {
      "name": "list_failed_services",
      "description": "List all failed systemd units.",
      "category": "systemd",
      "inputSchema": {
        "type": "object",
        "properties": {
          "unit_type": {
            "type": "string",
            "description": "Filter by unit type",
            "enum": ["service", "socket", "timer", "mount", "all"]
          }
        },
        "required": []
      },
      "outputSchema": {
        "type": "array",
        "description": "List of failed units"
      },
      "examples": [
        {
          "description": "List all failed units",
          "input": {}
        },
        {
          "description": "List failed services only",
          "input": {
            "unit_type": "service"
          }
        }
      ]
    },
    {
      "name": "get_systemd_units",
      "description": "List all systemd units by type and state.",
      "category": "systemd",
      "inputSchema": {
        "type": "object",
        "properties": {
          "unit_type": {
            "type": "string",
            "description": "Filter by unit type",
            "enum": ["service", "socket", "timer", "mount", "target", "device", "automount", "swap", "path", "all"]
          },
          "state": {
            "type": "string",
            "description": "Filter by state",
            "enum": ["loaded", "active", "inactive", "failed", "all"]
          }
        },
        "required": []
      },
      "outputSchema": {
        "type": "array",
        "description": "List of systemd units"
      },
      "examples": [
        {
          "description": "List all timers",
          "input": {
            "unit_type": "timer"
          }
        },
        {
          "description": "List all active sockets",
          "input": {
            "unit_type": "socket",
            "state": "active"
          }
        }
      ]
    },
    {
      "name": "get_unit_dependencies",
      "description": "Get dependency tree for a systemd unit.",
      "category": "systemd",
      "inputSchema": {
        "type": "object",
        "properties": {
          "unit_name": {
            "type": "string",
            "description": "Systemd unit name"
          },
          "dependency_type": {
            "type": "string",
            "description": "Dependency type",
            "enum": ["requires", "wants", "requisite", "binds-to", "part-of", "required-by", "wanted-by", "all"]
          }
        },
        "required": ["unit_name"]
      },
      "outputSchema": {
        "type": "object",
        "description": "Unit dependency information"
      },
      "examples": [
        {
          "description": "Get all dependencies for SSH",
          "input": {
            "unit_name": "sshd.service"
          }
        },
        {
          "description": "Get only 'requires' dependencies",
          "input": {
            "unit_name": "nginx.service",
            "dependency_type": "requires"
          }
        }
      ]    }
  ],
