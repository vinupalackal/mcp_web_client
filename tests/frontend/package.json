{
  "name": "mcp-client-frontend-tests",
  "version": "1.0.0",
  "description": "Jest tests for MCP Client Web frontend (app.js + settings.js)",
  "private": true,
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.4.2",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "jest-fetch-mock": "^3.0.3"
  },
  "jest": {
    "testEnvironment": "jsdom",
    "setupFiles": ["./setup-pre.js"],
    "setupFilesAfterEnv": ["./setup.js", "@testing-library/jest-dom"],
    "testMatch": ["**/*.test.js"],
    "clearMocks": true,
    "restoreMocks": true
  }
}
